pipeline {
    agent any

    environment {
        APP_NAME       = "python-demo"
        AWS_REGION     = "ap-southeast-1"
        AWS_ACCOUNT_ID = "093435167670"
        ECR_REPO       = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/python-demo"
        IMAGE_TAG      = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/centurion-ck/eks-.git'
            }
        }

        stage('Create Venv + Install Dependencies') {
            steps {
                sh '''
                python3 -m venv venv

                venv/bin/pip install --upgrade pip

                venv/bin/pip install -r requirements.txt
                '''
            }
        }

        stage('Unit Test') {
            steps {
                sh '''
                if [ -d tests ]; then
                    venv/bin/python -m pytest tests/ -v
                else
                    echo "No tests directory found. Skipping tests."
                fi
                '''
            }
        }

        stage('SonarQube Scan') {
            steps {
                script {

                    def scannerHome = tool 'sonar-scan'

                    withSonarQubeEnv('sonar-scann') {

                        sh """
                        ${scannerHome}/bin/sonar-scanner \
                        -Dsonar.projectKey=python-demo \
                        -Dsonar.projectName=python-demo \
                        -Dsonar.sources=. \
                        -Dsonar.python.version=3
                        """
                    }
                }
            }
        }

       stage('OWASP Dependency Check') {
    when {
        expression { false }
    }
    steps {
        dependencyCheck(
            odcInstallation: 'dep-check',
            additionalArguments: '--scan .'
        )
    }
}

        stage('Publish OWASP Report') {
            steps {
                dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
            }
        }

        stage('Trivy File System Scan') {
            steps {
                sh '''
                trivy fs . \
                --severity HIGH,CRITICAL
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                docker build \
                -t ${APP_NAME}:${IMAGE_TAG} .
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh '''
                trivy image \
                ${APP_NAME}:${IMAGE_TAG} \
                --severity HIGH,CRITICAL
                '''
            }
        }

        stage('Login To ECR') {
            steps {
                sh '''
                aws ecr get-login-password \
                --region ${AWS_REGION} | \
                docker login \
                --username AWS \
                --password-stdin \
                ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                '''
            }
        }

        stage('Push Image To ECR') {
            steps {
                sh '''
                docker tag \
                ${APP_NAME}:${IMAGE_TAG} \
                ${ECR_REPO}:${IMAGE_TAG}

                docker push \
                ${ECR_REPO}:${IMAGE_TAG}
                '''
            }
        }

        stage('Update Manifest') {
            steps {
                sh '''
                sed -i \
                "s|IMAGE_TAG|${IMAGE_TAG}|g" \
                k8s/deployment.yaml
                '''
            }
        }

        stage('Connect To EKS') {
            steps {
                sh '''
                aws eks update-kubeconfig \
                --region ${AWS_REGION} \
                --name shopeasy-cluster
                '''
            }
        }

        stage('Deploy To EKS') {
            steps {
                sh '''
                kubectl apply -f k8s/

                kubectl rollout status deployment/python-demo
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                kubectl get pods
                kubectl get svc
                '''
            }
        }
    }

    post {

        success {
            echo 'Pipeline SUCCESS'
        }

        failure {
            echo 'Pipeline FAILED'
        }

        always {
            cleanWs()
        }
    }
}